{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["src/main.tsx", "src/routes/**/*.tsx"],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": ["mcp-server/**", "scripts/**", "plugins/**"],
  "ignoreDependencies": ["tailwindcss", "tailwindcss-animate"],
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "src/components/ui/*.tsx": ["exports", "types"],
    "src/types/index.ts": ["exports", "types"],
    "src/themes/*.ts": ["exports", "types"],
    "src/config/theme.ts": ["exports"]
  }
}
